{
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "strict": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node", "vite/client", "bun-types"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "drizzle.config.ts",
    "vite.config.ts"
  ]
}
