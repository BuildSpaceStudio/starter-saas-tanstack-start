# Server-only secret key from BuildSpace Creator Studio
BUILDSPACE_SECRET_KEY=

# Browser-safe publishable key from BuildSpace Creator Studio
VITE_PUBLIC_BUILDSPACE_PUBLISHABLE_KEY=

# libSQL/Turso connection URL. Defaults to file:local.db locally when blank.
BUILDSPACE_DB_URL=

# libSQL auth token. Leave blank for local file DB development.
BUILDSPACE_DB_TOKEN=

# Public base URL used for auth callback redirects.
APP_URL=http://localhost:3000

# Session cookie name. Override only if you need to avoid collisions.
SESSION_COOKIE_NAME=bs_session
